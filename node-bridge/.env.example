# CodetyHub Node Bridge — Environment Variables
# Copy this file to .env and fill in your values.

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── ML Microservice ───────────────────────────────────────────────────────────
ML_API_URL=http://localhost:8000
ML_API_TIMEOUT_MS=15000

# Internal service-to-service token (checked by FastAPI middleware in production)
ML_SERVICE_TOKEN=

# ── Auth ──────────────────────────────────────────────────────────────────────
# Replace with your real JWT secret from your auth service
JWT_SECRET=dev-secret-change-in-production
